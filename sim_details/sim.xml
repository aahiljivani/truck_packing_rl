<mujoco>
    <!-- Truck segment: depth X=2.0, width Y=2.6, height Z=2.75 (half-sizes 1.0, 1.3, 1.375). U open toward -Y. -->
    <asset>
        <!-- Procedural plank-ish checker (no image file); texrepeat ~ grid on 2.0×2.6 m floor -->
        <texture name="wood_floor_tex" type="2d" builtin="flat" width="512" height="512"
            rgb1="0.58 0.38 0.22" rgb2="0.46 0.29 0.16"/>
        <material name="wood_floor" texture="wood_floor_tex" texuniform="false" texrepeat="10 13"
            specular="0.25" shininess="0.35"/>
    </asset>
    
    <visual>
  <headlight active="1"
             ambient="0.4 0.4 0.4"
             diffuse="0.8 0.8 0.8"
             specular="0.1 0.1 0.1"/>
</visual>

    <worldbody>
        <light diffuse="0.5 0.5 0.5" pos="0 0 4" dir="0 0 -1"/>

        <!-- Infinite floor plane at z=0 for robust contact -->
        <geom name="floor" type="plane" pos="0 0 0" size="2.0 2.0 0.1" material="wood_floor"/>

        <!-- Inner cavity: x in [-1,1], y in [-1.3,1.3], z in [0,2.75]. Wall half-thickness 0.01 (2 cm). -->
        <geom name="wall_back" type="box" pos="0 1.31 1.375" size="1.0 0.01 1.375" rgba="0.7 0.7 0.85 1"/>
        <geom name="wall_front_clear" type="box" pos="0 -1.31 1.375" size="1.0 0.01 1.375" rgba="0.7 0.7 0.85 0.15"/>
        <geom name="wall_left" type="box" pos="-1.01 0 1.375" size="0.01 1.3 1.375" rgba="0.7 0.7 0.85 1"/>
        <geom name="wall_right" type="box" pos="1.01 0 1.375" size="0.01 1.3 1.375" rgba="0.7 0.7 0.85 1"/>

        <geom name="ceiling" type="box" pos="0 0 2.74" size="1.0 1.3 0.01" rgba="0.7 0.7 0.85 1"/>

        <!-- <body name="cardboard_box" pos="0 0 0.12">
            <joint type="free"/>
            <geom type="box" size=".1 .1 .1" rgba="0.8 0.6 0.4 1"/>
        </body> -->
    </worldbody>
</mujoco>